/* pages/add-recipe/add-recipe.wxss — 与 add-food 表单风格一致 */

@import '../add-food/add-food.wxss';

.add-page {
  padding-bottom: 160rpx;
}

/* 封面图 */
.cover-picker {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 280rpx;
  background: #FFFFFF;
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius-lg);
}

.cover-picker__icon { font-size: 64rpx; }
.cover-picker__text { font-size: var(--font-size-sm); color: var(--color-text-hint); }

.cover-preview {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.cover-preview__img {
  width: 100%;
  height: 280rpx;
  display: block;
}

.cover-preview__actions {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  display: flex;
  gap: 12rpx;
}

.cover-action {
  padding: 8rpx 20rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: var(--font-size-xs);
  border-radius: var(--radius-full);
}

.cover-action--del { background: rgba(255, 107, 107, 0.85); }

/* 份量 */
.servings-row {
  display: flex;
  gap: 16rpx;
}

.serving-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.serving-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.form-input--sm {
  height: 72rpx;
  padding: 0 16rpx;
  text-align: center;
}

/* 动态列表卡片 */
.form-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.form-label-row .form-label { margin-bottom: 0; }

.link-add {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}

.dynamic-card {
  padding: 20rpx;
  margin-bottom: 16rpx;
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  border: 2rpx solid var(--color-border);
}

.dynamic-card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.dynamic-card__index {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.dynamic-card__remove {
  font-size: var(--font-size-xs);
  color: var(--color-danger);
}

.form-row--tight {
  margin-top: 12rpx;
  gap: 12rpx;
}

.essential-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 12rpx;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.essential-check {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid var(--color-border);
  border-radius: 8rpx;
  font-size: 22rpx;
  color: transparent;
}

.essential-check--on {
  background: var(--color-primary-gradient);
  border-color: var(--color-primary);
  color: #fff;
}

/* 食材名称自动补全 */
.ing-name-wrap {
  position: relative;
}

.suggestion-list {
  display: none;
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  z-index: 100;
  background: #fff;
  border-radius: var(--radius-md);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  max-height: 400rpx;
  overflow-y: auto;
  margin-top: 4rpx;
}

.suggestion-list--show {
  display: block;
}

.suggestion-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  border-bottom: 1rpx solid var(--color-border-light, #f0f0f0);
}

.suggestion-item:last-child {
  border-bottom: none;
}

.suggestion-item:active {
  background: var(--color-bg-secondary, #f7f7f7);
}

.suggestion-icon { font-size: 28rpx; }

.suggestion-hint {
  margin-left: auto;
  font-size: 22rpx;
  color: var(--color-primary);
}
