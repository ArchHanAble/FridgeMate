/* pages/recipe-detail/recipe-detail.wxss */

.recipe-detail-page {
  padding-bottom: 180rpx;
}

/* === 封面 === */
.detail-cover {
  position: relative;
  width: 100%;
  height: 440rpx;
  overflow: hidden;
}
.cover-image { width: 100%; height: 100%; }
.cover-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(180deg, rgba(0,0,0,0.1) 0%, transparent 40%, rgba(93,64,55,0.6) 100%);
}

.back-btn {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 16rpx);
  left: 24rpx;
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--color-text-primary);
  box-shadow: var(--shadow-sm);
}
.match-badge {
  position: absolute;
  bottom: 24rpx;
  left: 24rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 22rpx;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(10px);
  border-radius: var(--radius-lg);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}
.match-badge--ready {
  background: rgba(81,207,102,0.92); color: #fff; }
.ready-label { color: #b8fcc7; }

/* === 标题区 === */
.title-section { padding: 28rpx 28rpx 0; }
.recipe-name {
  display: block;
  font-size: var(--font-size-title);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  line-height: 1.3;
}
.recipe-desc {
  display: block;
  margin-top: 12rpx;
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  line-height: 1.6;
}
.meta-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 20rpx;
  padding-bottom: 24rpx;
  flex-wrap: wrap;
}
.meta-item {
  display: flex; align-items: center; gap: 6rpx;
  font-size: var(--font-size-xs);
  color: var(--color-text-hint);
}
.meta-item text:first-child { font-size: 26rpx; }
.meta-tags { display: inline-flex; gap: 10rpx; }
.tag-text { color: var(--color-primary-light); font-size: var(--font-size-xs); }

/* === 卡片通用 === */
.card { background: #FFFFFF; border-radius: var(--radius-card); padding: 28rpx; margin: 0 24rpx 20rpx; box-shadow: var(--shadow-sm); }
.card-title {
  display: flex; justify-content: space-between; align-items: center;
  font-size: var(--font-size-md); font-weight: var(--font-weight-bold); margin-bottom: 20rpx;
}
.servings-text { font-size: var(--font-size-sm); color: var(--color-text-hint); font-weight: normal; }

/* === 食材清单 === */
.ing-list { display: flex; flex-direction: column; gap: 4rpx; }
.ing-item {
  display: flex; align-items: center; gap: 14rpx; padding: 14rpx 8rpx;
  border-radius: var(--radius-sm); transition: background var(--duration-fast) ease-out;
}
.ing-item:active { background: var(--color-bg-secondary); }
.ing-item--miss .ing-name { opacity: 0.5; }

.ing-check {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; flex-shrink: 0;
  color: #fff;
}
.ing-item--has .ing-check { background: var(--status-fresh); }
.ing-item--miss .ing-check { background: var(--color-border); color: var(--color-text-hint); }

.ing-info { flex: 1; display: flex; flex-direction: column; gap: 2rpx; }
.ing-name { font-size: var(--font-size-base); font-weight: var(--font-weight-medium); color: var(--color-text-primary); }
.ing-name--miss { color: var(--color-text-hint); text-decoration: line-through; }
.ing-amount { font-size: var(--font-size-xs); color: var(--color-text-hint); }

.ing-essential {
  padding: 2rpx 12rpx; background: rgba(255,107,107,0.1);
  border-radius: var(--radius-full); font-size: 18rpx; color: var(--status-expired);
  font-weight: var(--font-weight-medium);
}

.missing-action {
  margin-top: 20rpx; padding-top: 16rpx; border-top: 1rpx dashed var(--color-border);
  display: flex; align-items: center; justify-content: space-between;
}
.missing-hint { font-size: var(--font-size-sm); color: var(--color-warning-dark || '#D9A000'); }
.btn-add-shopping {
  padding: 12rpx 24rpx; background: linear-gradient(135deg, #FFF3E0, #FFE8CC);
  border-radius: var(--radius-full); font-size: var(--font-size-xs); color: #E67700;
  border: none; font-weight: var(--font-weight-medium);
}
.btn-add-shopping:active { transform: scale(0.95); }

/* === 烹饪步骤 === */
.step-list { display: flex; flex-direction: column; gap: 28rpx; }
.step-item {
  display: flex; gap: 18rpx; align-items: flex-start;
}
.step-number-wrap { flex-shrink: 0; display: flex; flex-direction: column; align-items: center; }
.step-num {
  width: 52rpx; height: 52rpx; border-radius: 50%;
  background: var(--color-primary-gradient);
  color: #fff; font-size: var(--font-size-sm); font-weight: var(--font-weight-bold);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255,106,136,0.25);
}
.step-content { flex: 1; }
.step-image {
  width: 100%; height: 300rpx; border-radius: var(--radius-lg); margin-bottom: 12rpx;
  background: var(--color-bg-secondary);
}
.step-text {
  font-size: var(--font-size-base); color: var(--color-text-primary);
  line-height: 1.8;
}

/* === 营养信息 === */
.nutri-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12rpx; }
.nutri-item {
  display: flex; flex-direction: column; align-items: center; gap: 2rpx;
  padding: 16rpx 8rpx; background: var(--color-bg); border-radius: var(--radius-md);
}
.nutri-val { font-size: var(--font-size-lg); font-weight: var(--font-weight-bold); color: var(--color-primary); }
.nutri-unit { font-size: 18rpx; color: var(--color-text-hint); }
.nutri-label { font-size: var(--font-size-xs); color: var(--color-text-hint); }

/* === 底部操作栏 === */
.bottom-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  display: flex; gap: 10rpx; padding: 16rpx 20rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255,255,255,0.95); backdrop-filter: blur(20px);
  border-top: 1rpx solid var(--color-border); z-index: 99;
  align-items: center;
}

/* 次要操作按钮（编辑、收藏、做过） */
.action-sec {
  width: 150rpx !important; height: 72rpx;
  padding: 0 !important; margin: 0 !important;
  border-radius: var(--radius-md) !important;
  background: var(--color-bg-secondary) !important;
  color: var(--color-text-secondary) !important;
  border: none !important;
  display: flex; align-items: center; justify-content: center;
  font-size: var(--font-size-xs) !important; font-weight: var(--font-weight-medium) !important;
  flex-shrink: 0;
}
.action-sec:active { opacity: 0.7; transform: scale(0.96); }
.action-sec--done { color: #2B8A3E !important; background: linear-gradient(135deg, #E8F5E9, #C8E6C9) !important; }
.action-sec[disabled] { opacity: 0.5; }

/* 主要操作按钮（做好啦） */
.action-primary {
  flex: 1; height: 72rpx;
  border-radius: var(--radius-md) !important; border: none !important;
  background: linear-gradient(135deg, #BCAAA4, #A1887F) !important; color: #fff !important;
  font-size: var(--font-size-sm) !important; font-weight: var(--font-weight-bold) !important;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 1; min-width: 0;
}
.action-primary--ready {
  background: var(--color-primary-gradient) !important;
  box-shadow: 0 4rpx 16rpx rgba(255,106,136,0.35) !important;
}
.action-primary:active { transform: scale(0.97); opacity: 0.9; }

/* === 清耗食材弹窗 === */
.consume-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.consume-modal {
  width: 100%;
  max-height: 85vh;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.15);
  animation: slideUp 0.35s cubic-bezier(0.32, 0.72, 0, 1);
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.consume-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.consume-modal-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.consume-modal-icon {
  font-size: 40rpx;
}

.consume-modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.consume-modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
  border-radius: 50%;
  background: #f5f5f5;
  transition: all 0.2s ease;
}

.consume-modal-close:active {
  background: #e8e8e8;
  transform: scale(0.9);
}

.consume-modal-body {
  padding: 28rpx 32rpx;
  max-height: 65vh;
  overflow-y: auto;
}

.consume-modal-desc {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 28rpx;
  padding-left: 4rpx;
}

.consume-ingredient-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.consume-ingredient-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: #fafafa;
  border-radius: 20rpx;
  border: 2rpx solid #f0f0f0;
  transition: all 0.2s ease;
}

.consume-ingredient-item:active {
  background: #f5f5f5;
  border-color: #e8e8e8;
}

.consume-ingredient-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.consume-ingredient-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.consume-ingredient-unit {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

.consume-ingredient-quantity {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.quantity-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  font-size: 36rpx;
  color: #555;
  font-weight: 500;
  transition: all 0.15s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.quantity-btn:active {
  background: #f8f8f8;
  transform: scale(0.92);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.02);
}

.quantity-btn--minus {
  color: #ff6b6b;
  border-color: rgba(255, 107, 107, 0.3);
}

.quantity-btn--minus:active {
  background: rgba(255, 107, 107, 0.08);
}

.quantity-btn--plus {
  color: #51cf66;
  border-color: rgba(81, 207, 102, 0.3);
}

.quantity-btn--plus:active {
  background: rgba(81, 207, 102, 0.08);
}

.quantity-input {
  width: 110rpx;
  height: 60rpx;
  text-align: center;
  background: #fff;
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  box-shadow: inset 0 2rpx 6rpx rgba(0, 0, 0, 0.03);
}

.quantity-input:focus {
  border-color: #ff6a88;
  box-shadow: 0 0 0 4rpx rgba(255, 106, 136, 0.1);
}

.consume-modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f5f5f5;
  background: #fafafa;
}

.consume-btn-cancel {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  color: #666;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 20rpx;
  border: 2rpx solid #e8e8e8;
  transition: all 0.2s ease;
}

.consume-btn-cancel:active {
  background: #f5f5f5;
  transform: scale(0.98);
}

.consume-btn-confirm {
  flex: 1.5;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FF6A88, #FF8E53);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 20rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 106, 136, 0.35);
  transition: all 0.2s ease;
}

.consume-btn-confirm:active {
  opacity: 0.9;
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(255, 106, 136, 0.25);
}

/* === 美食照片上传 === */
.consume-section {
  margin-top: 32rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid #f0f0f0;
}

.consume-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.consume-upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 200rpx;
  background: #fafafa;
  border: 2rpx dashed #d9d9d9;
  border-radius: 20rpx;
  transition: all 0.2s ease;
}

.consume-upload-area:active {
  background: #f5f5f5;
  border-color: #ff6a88;
}

.upload-icon {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.upload-text {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.upload-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.consume-image-preview {
  position: relative;
  width: 100%;
  height: 300rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.consume-image-preview .preview-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.consume-image-preview .remove-img {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 24rpx;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.consume-image-preview .remove-img:active {
  background: rgba(0, 0, 0, 0.8);
  transform: scale(0.9);
}

/* === 心得体会 === */
.consume-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background: #fafafa;
  border: 2rpx solid #e8e8e8;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.consume-textarea:focus {
  border-color: #ff6a88;
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(255, 106, 136, 0.1);
}

.consume-placeholder {
  color: #bfbfbf;
  font-size: 28rpx;
}

/* ==================== 编辑模式样式 ==================== */

.edit-form-scroll {
  height: calc(100vh - 140rpx);
}

.edit-form {
  padding: 24rpx 24rpx 0;
}

.edit-section {
  margin-bottom: 32rpx;
}

.edit-section-title {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.edit-section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.edit-section-title-row .edit-section-title {
  margin-bottom: 0;
}

.required {
  color: var(--color-primary, #FF6A88);
  margin-left: 4rpx;
}

/* 编辑模式表单输入 */
.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #FFFFFF;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  box-sizing: border-box;
}

.form-input:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 4rpx rgba(255, 106, 136, 0.1);
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx 20rpx;
  background: #FFFFFF;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  line-height: 1.6;
  box-sizing: border-box;
}

.form-textarea:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 4rpx rgba(255, 106, 136, 0.1);
}

.form-row {
  display: flex;
  gap: 12rpx;
}

.form-row--tight {
  margin-top: 12rpx;
}

.form-input--half {
  flex: 1;
}

/* 难度选择器 */
.difficulty-picker {
  display: flex;
  gap: 16rpx;
}

.diff-option {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  transition: all 0.2s ease;
}

.diff-option--active {
  background: var(--color-primary-gradient, linear-gradient(135deg, #FF6A88, #FF8E53));
  border-color: var(--color-primary);
  color: #fff;
  font-weight: var(--font-weight-bold);
}

/* 封面图编辑（复用 add-recipe 样式） */
.cover-picker {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 220rpx;
  background: #FFFFFF;
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius-lg);
}

.cover-picker__icon { font-size: 56rpx; }
.cover-picker__text { font-size: var(--font-size-sm); color: var(--color-text-hint); }

.cover-preview {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.cover-preview__img {
  width: 100%;
  height: 280rpx;
  display: block;
}

.cover-preview__actions {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  display: flex;
  gap: 12rpx;
}

.cover-action {
  padding: 8rpx 20rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: var(--font-size-xs);
  border-radius: var(--radius-full);
}

.cover-action--del { background: rgba(255, 107, 107, 0.85); }

/* 动态列表卡片 */
.link-add {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}

.dynamic-card {
  padding: 20rpx;
  margin-bottom: 16rpx;
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  border: 2rpx solid var(--color-border);
}

.dynamic-card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.dynamic-card__index {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.dynamic-card__remove {
  font-size: var(--font-size-xs);
  color: var(--color-danger);
}

.essential-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 12rpx;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.essential-check {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid var(--color-border);
  border-radius: 8rpx;
  font-size: 22rpx;
  color: transparent;
}

.essential-check--on {
  background: var(--color-primary-gradient);
  border-color: var(--color-primary);
  color: #fff;
}

/* 编辑模式底部栏按钮 */
.edit-btn-cancel {
  flex: 1;
  height: 72rpx;
  border-radius: var(--radius-md) !important;
  background: var(--color-bg-secondary) !important;
  color: var(--color-text-primary) !important;
  font-size: var(--font-size-sm) !important;
  font-weight: var(--font-weight-medium) !important;
  border: 2rpx solid var(--color-border) !important;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-btn-cancel:active {
  background: #e8e8e8 !important;
  transform: scale(0.97);
}

.edit-btn-save {
  flex: 2;
  height: 72rpx;
  border-radius: var(--radius-md) !important;
  background: var(--color-primary-gradient) !important;
  color: #fff !important;
  font-size: var(--font-size-sm) !important;
  font-weight: var(--font-weight-bold) !important;
  border: none !important;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(255, 106, 136, 0.35);
}

.edit-btn-save:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.edit-btn-save--disabled {
  opacity: 0.6;
}
