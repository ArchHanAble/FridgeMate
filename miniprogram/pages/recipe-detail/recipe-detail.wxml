<!-- pages/recipe-detail/recipe-detail.wxml -->
<view class="page-container recipe-detail-page">
  <!-- ============ 查看模式 ============ -->
  <block wx:if="{{!isEditing}}">
    <!-- 封面图 -->
    <view class="detail-cover" bindtap="previewCoverImage">
      <image
        class="cover-image"
        src="{{image || '/images/placeholder-recipe.png'}}"
        mode="aspectFill"
      />
      <view class="cover-overlay">
        <view class="match-badge {{canCook ? 'match-badge--ready' : ''}}">
          <text>{{matchRate}}% 匹配</text>
          <text wx:if="{{canCook}}" class="ready-label">✓ 可做</text>
        </view>
      </view>
    </view>

    <!-- 标题区 -->
    <view class="title-section animate-fade-in-up">
      <text class="recipe-name">{{name}}</text>
      <text class="recipe-desc" wx:if="{{description}}">{{description}}</text>
      <view class="meta-row">
        <view class="meta-item">
          <text>⏱</text>
          <text>{{cookTime}}分钟</text>
        </view>
        <view class="meta-item">
          <text>📊</text>
          <text>{{difficultyLabel}}</text>
        </view>
        <view class="meta-tags" wx:if="{{tags && tags.length > 0}}">
          <text wx:for="{{tags}}" wx:key="index" class="tag-text">#{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 食材清单 -->
    <view class="card ingredients-card">
      <view class="card-title">
        <text>🥬 食材清单</text>
      </view>
      <view class="ing-list">
        <view 
          class="ing-item {{item.hasItem ? 'ing-item--has' : 'ing-item--miss'}}"
          wx:for="{{displayIngredients}}"
          wx:key="name"
        >
          <view class="ing-check">
            <text wx:if="{{item.hasItem}}">✓</text>
            <text wx:else>○</text>
          </view>
          <view class="ing-info">
            <text class="ing-name {{!item.hasItem ? 'ing-name--miss' : ''}}">{{item.name}}</text>
            <text class="ing-amount">{{item.amount}} {{item.unit}}</text>
          </view>
          <view class="ing-essential" wx:if="{{item.isEssential && !item.hasItem}}">
            <text>缺</text>
          </view>
        </view>
      </view>
      <view class="missing-action" wx:if="{{missingIngredients.length > 0 && !canCook}}">
        <text class="missing-hint">还差 {{missingIngredients.length}} 种食材</text>
        <button class="btn-add-shopping" catchtap="addMissingToShopping">🛒 加入购物清单</button>
      </view>
    </view>

    <!-- 烹饪步骤 -->
    <view class="card steps-card" wx:if="{{steps && steps.length > 0}}">
      <view class="card-title"><text>👨‍🍳 烹饪步骤</text></view>
      <view class="step-list">
        <view 
          class="step-item stagger-item"
          wx:for="{{steps}}"
          wx:key="order"
        >
          <view class="step-number-wrap">
            <view class="step-num">{{item.order}}</view>
          </view>
          <view class="step-content">
            <image
              wx:if="{{item.image}}"
              class="step-image"
              src="{{item.image}}"
              mode="aspectFill"
              bindtap="previewStepImage"
              data-url="{{item.image}}"
            />
            <text class="step-text">{{item.text}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 营养信息 -->
    <view class="card nutrition-card" wx:if="{{nutrition}}">
      <view class="card-title"><text>📊 营养成分（每份）</text></view>
      <view class="nutri-grid">
        <view class="nutri-item">
          <text class="nutri-val">{{nutrition.calories || '-'}}</text>
          <text class="nutri-unit">kcal</text>
          <text class="nutri-label">热量</text>
        </view>
        <view class="nutri-item">
          <text class="nutri-val">{{nutrition.protein || '-'}}</text>
          <text class="nutri-unit">g</text>
          <text class="nutri-label">蛋白质</text>
        </view>
        <view class="nutri-item">
          <text class="nutri-val">{{nutrition.carbs || '-'}}</text>
          <text class="nutri-unit">g</text>
          <text class="nutri-label">碳水</text>
        </view>
        <view class="nutri-item">
          <text class="nutri-val">{{nutrition.fat || '-'}}</text>
          <text class="nutri-unit">g</text>
          <text class="nutri-label">脂肪</text>
        </view>
      </view>
    </view>
  </block>

  <!-- ============ 编辑模式 ============ -->
  <scroll-view scroll-y class="edit-form-scroll" wx:if="{{isEditing}}">
    <view class="edit-form">
      <!-- 封面图编辑 -->
      <view class="edit-section">
        <view class="edit-section-title">封面图</view>
        <view class="cover-picker" bindtap="chooseEditCover" wx:if="{{!editImageUrl}}">
          <text class="cover-picker__icon">📷</text>
          <text class="cover-picker__text">点击上传菜谱封面（留空则保持不变）</text>
        </view>
        <view class="cover-preview" wx:else>
          <image class="cover-preview__img" src="{{editImageUrl}}" mode="aspectFill" />
          <view class="cover-preview__actions">
            <text class="cover-action" bindtap="chooseEditCover">更换</text>
            <text class="cover-action cover-action--del" bindtap="removeEditCover">删除</text>
          </view>
        </view>
      </view>

      <!-- 菜名 -->
      <view class="edit-section">
        <view class="edit-section-title">菜名 <text class="required">*</text></view>
        <input
          class="form-input"
          placeholder="例如：西红柿炒鸡蛋"
          value="{{editName}}"
          bindinput="onEditInput"
          data-field="editName"
          maxlength="40"
        />
      </view>

      <!-- 简介 -->
      <view class="edit-section">
        <view class="edit-section-title">简介</view>
        <textarea
          class="form-textarea"
          placeholder="简单描述这道菜..."
          value="{{editDescription}}"
          bindinput="onEditInput"
          data-field="editDescription"
          maxlength="200"
          auto-height
        />
      </view>

      <!-- 烹饪时长 -->
      <view class="edit-section">
        <view class="edit-section-title">烹饪时长（分钟）</view>
        <input
          class="form-input"
          type="number"
          placeholder="15"
          value="{{editCookTime}}"
          bindinput="onEditInput"
          data-field="editCookTime"
        />
      </view>

      <!-- 难度 -->
      <view class="edit-section">
        <view class="edit-section-title">难度</view>
        <view class="difficulty-picker">
          <view
            wx:for="{{editDifficulties}}"
            wx:key="value"
            class="diff-option {{editDifficulty === item.value ? 'diff-option--active' : ''}}"
            data-value="{{item.value}}"
            bindtap="selectEditDifficulty"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>

      <!-- 标签 -->
      <view class="edit-section">
        <view class="edit-section-title">标签</view>
        <input
          class="form-input"
          placeholder="用逗号分隔，如：快手菜,下饭菜"
          value="{{editTagsText}}"
          bindinput="onEditInput"
          data-field="editTagsText"
          maxlength="80"
        />
      </view>

      <!-- 食材列表 -->
      <view class="edit-section">
        <view class="edit-section-title-row">
          <text class="edit-section-title">食材 <text class="required">*</text></text>
          <text class="link-add" bindtap="addEditIngredient">+ 添加食材</text>
        </view>

        <view
          class="dynamic-card"
          wx:for="{{editIngredients}}"
          wx:for-item="ing"
          wx:for-index="ingIdx"
          wx:key="id"
        >
          <view class="dynamic-card__head">
            <text class="dynamic-card__index">食材 {{ingIdx + 1}}</text>
            <text
              class="dynamic-card__remove"
              data-ing-index="{{ingIdx}}"
              catchtap="removeEditIngredient"
              wx:if="{{editIngredients.length > 1}}"
            >删除</text>
          </view>
          <input
            class="form-input"
            placeholder="食材名称"
            value="{{ing.name}}"
            data-ing-index="{{ingIdx}}"
            data-field="name"
            bindinput="onEditIngredientInput"
          />
          <view class="form-row form-row--tight">
            <input
              class="form-input form-input--half"
              placeholder="用量"
              value="{{ing.amount}}"
              data-ing-index="{{ingIdx}}"
              data-field="amount"
              bindinput="onEditIngredientInput"
            />
            <input
              class="form-input form-input--half"
              placeholder="单位"
              value="{{ing.unit}}"
              data-ing-index="{{ingIdx}}"
              data-field="unit"
              bindinput="onEditIngredientInput"
            />
          </view>
          <view class="essential-row" data-ing-index="{{ingIdx}}" catchtap="toggleEditIngredientEssential">
            <text class="essential-check {{ing.isEssential ? 'essential-check--on' : ''}}">{{ing.isEssential ? '✓' : ''}}</text>
            <text>必需食材</text>
          </view>
        </view>
      </view>

      <!-- 步骤列表 -->
      <view class="edit-section">
        <view class="edit-section-title-row">
          <text class="edit-section-title">做法步骤 <text class="required">*</text></text>
          <text class="link-add" bindtap="addEditStep">+ 添加步骤</text>
        </view>

        <view class="dynamic-card" wx:for="{{editSteps}}" wx:key="index">
          <view class="dynamic-card__head">
            <text class="dynamic-card__index">步骤 {{index + 1}}</text>
            <text class="dynamic-card__remove" data-index="{{index}}" catchtap="removeEditStep" wx:if="{{editSteps.length > 1}}">删除</text>
          </view>
          <textarea
            class="form-textarea"
            placeholder="描述这一步怎么做..."
            value="{{item.text}}"
            data-index="{{index}}"
            bindinput="onEditStepInput"
            auto-height
            maxlength="500"
          />
        </view>
      </view>

      <!-- 底部留白 -->
      <view style="height: 140rpx;"></view>
    </view>
  </scroll-view>

  <!-- ============ 底部操作栏 ============ -->
  <!-- 查看模式底部栏 -->
  <view class="bottom-bar safe-area-bottom" wx:if="{{!isEditing}}">
    <button class="action-sec" bindtap="startEdit">✏️ 编辑</button>
    <button class="action-sec" bindtap="toggleFavorite">{{isFavorited ? '❤️ 已收藏' : '🤍 收藏'}}</button>
    <button
      class="action-sec {{isRecorded ? 'action-sec--done' : ''}}"
      catchtap="handleRecordCook"
      disabled="{{isRecording || isRecorded}}"
    >{{isRecording ? '⏳ 记录中' : (isRecorded ? '✅ 已做' : '📝 做过')}}</button>
    <button
      class="action-primary {{canCook ? 'action-primary--ready' : ''}}"
      catchtap="showConsumeModal"
    >⚡ 做好啦</button>
  </view>

  <!-- 编辑模式底部栏 -->
  <view class="bottom-bar safe-area-bottom" wx:if="{{isEditing}}">
    <button class="edit-btn-cancel" bindtap="cancelEdit">取消</button>
    <button class="edit-btn-save {{editSubmitting ? 'edit-btn-save--disabled' : ''}}" bindtap="submitEdit">
      <text>{{editSubmitting ? '保存中...' : '💾 保存'}}</text>
    </button>
  </view>

  <!-- 消耗食材弹窗 -->
  <view class="consume-modal-mask" wx:if="{{showConsumeModal}}" bindtap="hideConsumeModal">
    <view class="consume-modal" catchtap="preventBubble">
      <view class="consume-modal-header">
        <view class="consume-modal-title-wrap">
          <text class="consume-modal-icon">📦</text>
          <text class="consume-modal-title">做菜记录</text>
        </view>
        <view class="consume-modal-close" bindtap="hideConsumeModal">✕</view>
      </view>
      
      <scroll-view scroll-y class="consume-modal-body">
        <view class="consume-modal-desc">请确认要消耗的食材数量，可手动调整</view>
        
        <view class="consume-ingredient-list">
          <view class="consume-ingredient-item" wx:for="{{consumeIngredients}}" wx:key="name">
            <view class="consume-ingredient-info">
              <text class="consume-ingredient-name">{{item.name}}</text>
              <text class="consume-ingredient-unit">（{{item.unit}}）</text>
            </view>
            <view class="consume-ingredient-quantity">
              <view class="quantity-btn quantity-btn--minus" bindtap="decreaseQuantity" data-index="{{index}}">
                <text>-</text>
              </view>
              <input 
                class="quantity-input" 
                type="digit" 
                value="{{item.amount}}" 
                bindinput="onQuantityInput"
                data-index="{{index}}"
              />
              <view class="quantity-btn quantity-btn--plus" bindtap="increaseQuantity" data-index="{{index}}">
                <text>+</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 美食照片上传 -->
        <view class="consume-section">
          <view class="consume-section-title">美食照片</view>
          <view class="consume-upload-area" wx:if="{{!foodPhoto}}" bindtap="onChooseFoodPhoto">
            <text class="upload-icon">📷</text>
            <text class="upload-text">上传美食照片</text>
            <text class="upload-hint">非必填，留空则显示菜谱照片</text>
          </view>
          <view class="consume-image-preview" wx:if="{{foodPhoto}}">
            <image class="preview-img" src="{{foodPhoto}}" mode="aspectFill" />
            <view class="remove-img" bindtap="removeFoodPhoto">✕</view>
          </view>
        </view>

        <!-- 心得体会 -->
        <view class="consume-section">
          <view class="consume-section-title">心得体会</view>
          <textarea
            class="consume-textarea"
            placeholder="分享你的做菜心得吧..."
            placeholder-class="consume-placeholder"
            value="{{experience}}"
            bindinput="onExperienceInput"
            maxlength="500"
            auto-height
          />
        </view>
      </scroll-view>
      
      <view class="consume-modal-footer">
        <button class="consume-btn-cancel" bindtap="hideConsumeModal">取消</button>
        <button class="consume-btn-confirm" bindtap="confirmConsume">确认</button>
      </view>
    </view>
  </view>
</view>
