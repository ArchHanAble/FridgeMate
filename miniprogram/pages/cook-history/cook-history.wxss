/* pages/cook-history/cook-history.wxss */
/* 现代简约风格 - 优化配色、间距与交互 */

.cook-history-page {
  padding: 32rpx 32rpx 48rpx;
  min-height: 100vh;
  background: #F7F9FC;
}

/* === 顶部操作栏 === */
.top-bar {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
  width: 100%;
}

.search-box {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
  flex: 1;
  box-sizing: border-box;
}

.search-box:focus-within {
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.15);
}

.search-icon-text {
  font-size: 28rpx;
  margin-right: 16rpx;
  opacity: 0.6;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #2D3436;
}

.search-placeholder {
  color: #B2BEC3;
}

.search-close {
  padding: 8rpx 16rpx;
  color: #636E72;
  font-size: 28rpx;
  transition: all 0.2s ease;
}

.search-close:active {
  opacity: 0.6;
}

.top-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-left: auto;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 18rpx 32rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.action-btn:active {
  transform: scale(0.96);
}

.search-toggle {
  background: #fff;
  color: #636E72;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.search-toggle:active {
  background: #F7F9FC;
}

.add-btn {
  background: linear-gradient(135deg, #FF6B6B, #FFA07A);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.3);
}

.add-btn:active {
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 107, 0.3);
}

.action-icon {
  font-size: 32rpx;
}

/* === 加载状态 === */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
  gap: 24rpx;
  color: #B2BEC3;
  font-size: 28rpx;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #FFE0E0;
  border-top-color: #FF6B6B;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* === 时间轴布局 === */
.timeline {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.timeline-item {
  display: flex;
  gap: 28rpx;
  position: relative;
  transition: all 0.3s ease;
}

/* 移除 timeline-item 的 active 效果，避免图片预览关闭后造成页面刷新的视觉效果 */
/* .timeline-item:active {
  transform: scale(0.98);
} */

/* 时间轴线 */
.timeline-dot-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 36rpx;
  flex-shrink: 0;
  position: relative;
}

.timeline-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B6B, #FFA07A);
  margin-top: 44rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 107, 0.4);
  position: relative;
  z-index: 1;
  transition: all 0.3s ease;
}

/* 移除 timeline-item:active 的 dot 缩放效果，避免图片预览关闭后造成页面刷新的视觉效果 */
/* .timeline-item:active .timeline-dot {
  transform: scale(1.2);
} */

.timeline-line {
  width: 4rpx;
  flex: 1;
  background: linear-gradient(to bottom, #FFD0D0, #FFE8E8);
  margin-top: 8rpx;
}

/* 内容卡片 - 上下布局 */
.timeline-card {
  flex: 1;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 卡片上半部分 - 左右布局（图片+信息） */
.timeline-card-top {
  display: flex;
  gap: 24rpx;
}

/* 移除 timeline-card 的 active 效果，避免图片预览关闭后造成页面刷新的视觉效果 */
/* .timeline-card:active {
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
} */

.timeline-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 8rpx;
  height: 100%;
  background: linear-gradient(to bottom, #FF6B6B, #FFA07A);
  border-radius: 8rpx 0 0 8rpx;
}

/* 左侧：菜品图片 */
.timeline-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f5f5f5;
  transition: all 0.3s ease;
}

.timeline-image:active {
  opacity: 0.9;
}

/* 无图片时的占位符 */
.timeline-image-placeholder {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #F7F9FC;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #E9ECEF;
}

.placeholder-icon {
  font-size: 64rpx;
  opacity: 0.5;
}

/* 右侧：信息区域 */
.timeline-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 0; /* 防止文本溢出 */
}

.timeline-date {
  font-size: 24rpx;
  color: #FF6B6B;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.timeline-date::before {
  content: '📅';
  font-size: 24rpx;
}

.timeline-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D3436;
  display: block;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 消耗食材 */
.timeline-ingredients {
  margin-top: 4rpx;
}

.ingredients-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.ingredients-summary {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.ingredients-icon {
  font-size: 24rpx;
}

.ingredients-count {
  font-size: 24rpx;
  color: #FF8C00;
  font-weight: 500;
}

.ingredients-toggle {
  font-size: 22rpx;
  color: #FF8C00;
  font-weight: 500;
  padding: 4rpx 12rpx;
  background: #FFF3E0;
  border-radius: 8rpx;
}

/* 食材详情列表 */
.ingredients-detail {
  margin-top: 12rpx;
  padding: 16rpx;
  background: #FFF9F0;
  border-radius: 12rpx;
  border: 2rpx solid #FFE8CC;
}

.ingredient-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #FFE8CC;
}

.ingredient-item:last-child {
  border-bottom: none;
}

.ingredient-name {
  font-size: 24rpx;
  color: #2D3436;
  font-weight: 500;
  flex: 1;
}

.ingredient-amount {
  font-size: 22rpx;
  color: #FF8C00;
  font-weight: 600;
  background: #FFF3E0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 12rpx;
}

.ingredient-amount--unknown {
  color: #B2BEC3;
  background: #F5F5F5;
  font-style: italic;
}

/* 做菜心得 */
.timeline-experience {
  background: #F7F9FC;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-top: 8rpx;
  border-top: 2rpx solid #E9ECEF;
}

.experience-header {
  margin-bottom: 12rpx;
}

.experience-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #2D3436;
}

.experience-text {
  font-size: 26rpx;
  color: #636E72;
  line-height: 1.7;
  word-break: break-all;
}

.experience-text--collapsed {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.experience-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 16rpx;
  padding: 12rpx 0 4rpx;
  border-top: 1rpx solid #E9ECEF;
}

.experience-toggle-text {
  font-size: 24rpx;
  color: #FF6B6B;
  font-weight: 500;
}

.experience-toggle-icon {
  font-size: 20rpx;
  color: #FF6B6B;
}

/* === 弹窗遮罩 === */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  animation: fadeIn 0.3s ease;
}

.modal-content {
  width: 100%;
  max-height: 85vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

.modal-content--middle {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 90%;
  max-height: 70vh;
  border-radius: 24rpx;
  animation: scaleIn 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes scaleIn {
  from { opacity: 0; transform: translate(-50%, -48%) scale(0.96); }
  to { opacity: 1; transform: translate(-50%, -50%) scale(1); }
}

/* === 弹窗头部 === */
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 36rpx 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D3436;
}

.modal-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #636E72;
  font-size: 36rpx;
  border-radius: 50%;
  background: #F7F9FC;
  transition: all 0.2s ease;
}

.modal-close:active {
  background: #E9ECEF;
}

/* === 弹窗主体 === */
.modal-body {
  flex: 1;
  padding: 28rpx 36rpx;
  max-height: 60vh;
}

.form-section {
  margin-bottom: 36rpx;
}

.form-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 20rpx;
}

/* 图片上传 */
.image-upload-area {
  width: 100%;
  height: 240rpx;
  border: 2rpx dashed #DDD;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #FAFAFA;
  transition: all 0.3s ease;
}

.image-upload-area:active {
  background: #F0F0F0;
  border-color: #FF6B6B;
}

.upload-icon {
  font-size: 56rpx;
  opacity: 0.5;
}

.upload-text {
  font-size: 28rpx;
  color: #999;
}

.image-preview {
  position: relative;
  width: 100%;
  height: 360rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.preview-img {
  width: 100%;
  height: 100%;
}

.remove-img {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  transition: all 0.2s ease;
}

.remove-img:active {
  background: rgba(0, 0, 0, 0.8);
}

.uploading-tip {
  font-size: 26rpx;
  color: #FF6B6B;
  margin-top: 12rpx;
}

/* 表单输入 */
.form-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #E9ECEF;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: #2D3436;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.form-input:focus {
  border-color: #FF6B6B;
  box-shadow: 0 0 0 4rpx rgba(255, 107, 107, 0.1);
}

.form-placeholder {
  color: #B2BEC3;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  border: 2rpx solid #E9ECEF;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  transition: all 0.3s ease;
}

.form-picker:active {
  background: #F7F9FC;
}

.picker-value {
  color: #2D3436;
}

.picker-value.placeholder {
  color: #B2BEC3;
}

.picker-arrow {
  color: #B2BEC3;
  font-size: 28rpx;
}

.form-textarea {
  width: 100%;
  min-height: 180rpx;
  border: 2rpx solid #E9ECEF;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  color: #2D3436;
  box-sizing: border-box;
  line-height: 1.6;
  transition: all 0.3s ease;
}

.form-textarea:focus {
  border-color: #FF6B6B;
  box-shadow: 0 0 0 4rpx rgba(255, 107, 107, 0.1);
}

/* === 弹窗底部 === */
.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 28rpx 36rpx 52rpx;
  border-top: 1rpx solid #F0F0F0;
}

.btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.btn:active {
  transform: scale(0.96);
}

.btn-cancel {
  background: #F7F9FC;
  color: #636E72;
}

.btn-cancel:active {
  background: #E9ECEF;
}

.btn-submit {
  background: linear-gradient(135deg, #FF6B6B, #FFA07A);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.3);
}

.btn-submit:active {
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 107, 0.3);
}

/* === 菜谱选择弹窗 === */
.picker-search {
  padding: 20rpx 36rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.picker-search-input {
  width: 100%;
  height: 80rpx;
  background: #F7F9FC;
  border-radius: 40rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: #2D3436;
  transition: all 0.3s ease;
}

.picker-search-input:focus {
  background: #FFF;
  box-shadow: 0 0 0 4rpx rgba(255, 107, 107, 0.1);
}

.picker-list {
  max-height: 50vh;
  padding: 12rpx 0;
}

.picker-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 36rpx;
  border-bottom: 1rpx solid #F9F9F9;
  transition: all 0.2s ease;
}

.picker-item:active {
  background: #F7F9FC;
}

.picker-item-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.picker-item-img--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  background: #F7F9FC;
}

.picker-item-name {
  font-size: 30rpx;
  color: #2D3436;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
}

.picker-empty {
  padding: 80rpx 0;
  text-align: center;
  color: #B2BEC3;
  font-size: 28rpx;
}

/* === 评论区域 === */
.comment-section {
  border-top: 1rpx solid #F0F0F0;
  padding-top: 16rpx;
}

/* 评论列表 */
.comment-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 16rpx;
  max-height: 320rpx;
  overflow-y: auto;
}

.comment-item {
  display: flex;
  gap: 16rpx;
}

.comment-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #F0F0F0;
}

.comment-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.comment-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.comment-nickname {
  font-size: 24rpx;
  color: #FF6B6B;
  font-weight: 500;
}

.comment-time {
  font-size: 20rpx;
  color: #B2BEC3;
}

.comment-content {
  font-size: 26rpx;
  color: #636E72;
  line-height: 1.5;
  word-break: break-all;
}

/* 评论输入区 */
.comment-input-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #F7F9FC;
  border-radius: 40rpx;
  padding: 8rpx 8rpx 8rpx 28rpx;
}

.comment-input {
  flex: 1;
  font-size: 26rpx;
  color: #2D3436;
  height: 64rpx;
  line-height: 64rpx;
}

.comment-placeholder {
  color: #B2BEC3;
}

.comment-send-btn {
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: #B2BEC3;
  font-weight: 500;
  border-radius: 32rpx;
  background: #E9ECEF;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.comment-send-btn--active {
  color: #fff;
  background: linear-gradient(135deg, #FF6B6B, #FFA07A);
}

.comment-send-btn--active:active {
  transform: scale(0.95);
  opacity: 0.85;
}

.comment-sending {
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

/* === 删除气泡 === */
.delete-bubble-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.25);
}

.delete-bubble {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 48rpx;
  background: linear-gradient(135deg, #FFFFFF, #FFF5F5);
  border-radius: var(--radius-xl);
  box-shadow: 0 12rpx 40rpx rgba(255, 68, 68, 0.2);
  animation: delete-bubble-in 0.25s var(--ease-out);
  gap: 20rpx;
}

.delete-bubble__tip {
  font-size: var(--font-size-sm);
  color: var(--color-text-hint);
}

.delete-bubble__action {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF4444);
  border-radius: var(--radius-full);
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 107, 0.4);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-bold);
  color: #FFFFFF;
  white-space: nowrap;
}

.delete-bubble__action:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.delete-bubble__icon {
  font-size: 32rpx;
}

.delete-bubble__arrow {
  position: absolute;
  top: -16rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 16rpx solid transparent;
  border-right: 16rpx solid transparent;
  border-bottom: 16rpx solid rgba(255, 255, 255, 0.95);
}

@keyframes delete-bubble-in {
  0% {
    opacity: 0;
    transform: scale(0.8) translateY(20rpx);
  }
  100% {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

/* === 统计表格 === */
.stats-section {
  margin-bottom: 40rpx;
}

.stats-table {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.stats-table:active {
  transform: scale(0.98);
}

.stats-table::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 8rpx;
  height: 100%;
  background: linear-gradient(to bottom, #FF6B6B, #FFA07A);
  border-radius: 8rpx 0 0 8rpx;
}

.stats-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.stats-row:last-child {
  border-bottom: none;
}

.stats-cell--label {
  font-size: 30rpx;
  color: #636E72;
  font-weight: 500;
}

.stats-cell--value {
  font-size: 36rpx;
  color: #2D3436;
  font-weight: 700;
}

.stats-cell--dish {
  color: #FF6B6B;
  max-width: 320rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* === 加载更多 === */
.load-more-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0 60rpx;
  gap: 16rpx;
}

.load-more-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 48rpx;
  background: #fff;
  border-radius: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  font-size: 28rpx;
  color: #FF6B6B;
  font-weight: 500;
  transition: all 0.2s ease;
}

.load-more-btn:active {
  background: #FFF0F0;
  transform: scale(0.96);
}

.load-more-hint {
  font-size: 22rpx;
  color: #B2BEC3;
  font-weight: 400;
}

.load-more-loading {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 26rpx;
  color: #B2BEC3;
}

.loading-spinner-sm {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid #FFE0E0;
  border-top-color: #FF6B6B;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.no-more {
  font-size: 24rpx;
  color: #B2BEC3;
  text-align: center;
  padding: 16rpx 0;
}
