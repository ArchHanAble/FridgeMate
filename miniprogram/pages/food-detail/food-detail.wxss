/* pages/food-detail/food-detail.wxss
 * 视觉风格：暖灰底色 + 圆角卡片 + 左对齐时间轴
 * 色彩系统：主色 #1a1a1a / 过期红 #E24B4A / AI 暖黄 #FAEEDA / 绿 #639922
 */

.detail-page {
  padding: 0 28rpx 180rpx;
  background: #f5f0eb;
  min-height: 100vh;
}

/* ==================== Hero 卡片 ==================== */
.hero-card {
  background: #fff;
  border-radius: 36rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.food-name {
  font-size: 44rpx;
  font-weight: 500;
  color: #1a1a1a;
  line-height: 1.3;
}

/* 过期角标（红色药丸） */
.expired-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #FCEBEB;
  border-radius: 40rpx;
  padding: 8rpx 20rpx;
  flex-shrink: 0;
}
.expired-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #E24B4A;
}
.expired-text {
  font-size: 22rpx;
  color: #A32D2D;
  font-weight: 500;
}

/* 临期角标（橙色） */
.expiring-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #FFF3E0;
  border-radius: 40rpx;
  padding: 8rpx 20rpx;
  flex-shrink: 0;
}
.expiring-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #E67700;
}
.expiring-text {
  font-size: 22rpx;
  color: #A05600;
  font-weight: 500;
}

/* 分类标签 */
.category-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  background: #F1EFE8;
  border-radius: 40rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: #5F5E5A;
  margin-bottom: 28rpx;
}

/* 信息行：品牌 | 数量 | 位置 */
.info-row {
  display: flex;
  align-items: flex-start;
  gap: 0;
}
.info-item {
  flex: 1;
  min-width: 0;
}
.info-label {
  font-size: 22rpx;
  color: #888780;
  margin-bottom: 4rpx;
}
.info-value {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
}
.info-divider {
  width: 1rpx;
  height: 52rpx;
  background: #e8e5e0;
  margin: 0 28rpx;
  flex-shrink: 0;
  align-self: stretch;
  margin-top: 24rpx;
}

/* ==================== 通用卡片 ==================== */
.section-card {
  background: #fff;
  border-radius: 36rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #888780;
  margin-bottom: 28rpx;
  letter-spacing: 0.02em;
}

/* ==================== 时间轴（左对齐式）==================== */
.timeline {
  position: relative;
  padding-left: 40rpx;
}

/* 渐变竖线背景：绿 → 红 */
.timeline-line {
  position: absolute;
  left: 10rpx;
  top: 16rpx;
  bottom: 16rpx;
  width: 3rpx;
  background: linear-gradient(to bottom, #97C459, #E24B4A);
  border-radius: 2rpx;
}

.timeline-item {
  position: relative;
  margin-bottom: 28rpx;
}
.timeline-item:last-child {
  margin-bottom: 0;
}

/* 圆点（绝对定位在左侧线上） */
.tl-dot {
  position: absolute;
  left: -40rpx;
  top: 6rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-sizing: border-box;
}
.tl-dot--green { background: #639922; }
.tl-dot--red { background: #E24B4A; }
.tl-dot--orange { background: #E67700; }
.tl-dot--gray { background: #B4B2A9; }
.tl-dot--today {
  background: #E24B4A;
  border-color: #FCEBEB;
  box-shadow: 0 0 0 4rpx #E24B4A;
}

.tl-content {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.tl-label { font-size: 22rpx; color: #888780; }
.tl-date { font-size: 28rpx; font-weight: 500; color: #1a1a1a; }

/* 过期日期红色 */
.tl-date--expired { color: #A32D2D; }
.tl-date--expiring { color: #A05600; }

/* 今天标签 */
.tl-today-badge {
  font-size: 22rpx;
  color: #A32D2D;
  background: #FCEBEB;
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
  display: inline-block;
  margin-top: 4rpx;
}

/* ==================== 进度条 ==================== */
.progress-bar {
  margin-top: 28rpx;
  height: 8rpx;
  background: #F1EFE8;
  border-radius: 4rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.8s ease-out;
}
.progress-fill--fresh { background: #639922; }
.progress-fill--expiring { background: #E67700; }
.progress-fill--expired { background: #E24B4A; }

.progress-label {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
}
.progress-label text { font-size: 20rpx; color: #B4B2A9; }

/* ==================== AI 处理建议（暖色调卡片）==================== */
.ai-section {
  background: #FAEEDA;
  border-radius: 36rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
}
.ai-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.ai-icon {
  width: 40rpx;
  height: 40rpx;
  background: #EF9F27;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ai-icon-inner {
  font-size: 22rpx;
  color: #fff;
  line-height: 1;
}
.ai-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #633806;
}
.ai-body {
  font-size: 26rpx;
  color: #854F0B;
  line-height: 1.75;
}
.ai-tip {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(186,117,23,0.2);
  font-size: 24rpx;
  color: #BA7517;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}
.ai-tip-icon { flex-shrink: 0; line-height: 1.4; }

/* ==================== 备注 ==================== */
.note-card {
  background: #fff;
  border-radius: 36rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
}
.note-content { font-size: 26rpx; color: var(--color-text-secondary); line-height: 1.7; }

/* ==================== 底部操作按钮 ==================== */
.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 20rpx;
  padding: 24rpx 28rpx calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(245,240,235,0.95);
  backdrop-filter: blur(20px);
  z-index: 99;
}

.btn-primary,
.btn-secondary,
.btn-edit {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
  border: none;
  line-height: 88rpx;
  padding: 0;
}

.btn-primary {
  background: #1a1a1a;
  color: #fff;
}
.btn-edit {
  background: #FFF3E0;
  color: #E67700;
  border: 1rpx solid rgba(230,119,0,0.2);
}
.btn-secondary {
  background: #fff;
  color: #1a1a1a;
  border: 1rpx solid rgba(0,0,0,0.12);
}

.hover-scale { transform: scale(0.97); opacity: 0.92; }
.hover-scale-light { transform: scale(0.97); opacity: 0.85; background: #f5f5f5; }

/* ==================== 调整库存弹窗 ==================== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-container {
  width: 100%;
  max-height: 90vh;
  background: #f5f0eb;
  border-radius: 36rpx 36rpx 0 0;
  padding: 0 32rpx 48rpx;
  animation: slideUp 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  overflow-y: auto;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

/* 顶部拖拽指示条 */
.modal-indicator {
  width: 64rpx;
  height: 8rpx;
  background: #d9d9d9;
  border-radius: 4rpx;
  margin: 16rpx auto 24rpx;
}

/* 标题栏 */
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.modal-title-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.modal-icon {
  font-size: 36rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  letter-spacing: 0.02em;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.05);
}

.close-icon {
  font-size: 28rpx;
  color: #666;
  font-weight: 400;
}

/* 食材信息卡片 */
.stock-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.stock-card-left {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.stock-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.stock-current-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.stock-current-label {
  font-size: 24rpx;
  color: #888780;
}

.stock-current-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1;
}

.stock-unit {
  font-size: 24rpx;
  color: #888780;
}

.stock-card-badge {
  background: #f5f0eb;
  border-radius: 16rpx;
  padding: 12rpx 24rpx;
}

.badge-text {
  font-size: 24rpx;
  color: #888780;
  font-weight: 500;
}

/* 调整操作区 */
.adjust-area {
  margin-bottom: 32rpx;
}

/* 快速调整模式 */
.quick-adjust-header,
.precise-adjust-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.adjust-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
}

.mode-switch-btn {
  padding: 8rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.switch-text {
  font-size: 24rpx;
  color: #666;
}

/* 核心操作区：加减按钮 + 数字 */
.core-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 32rpx;
}

.control-btn {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: all 0.2s;
}

.control-btn:active {
  transform: scale(0.92);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.12);
}

.control-btn.minus {
  background: #fff;
}

.control-btn.plus {
  background: #1a1a1a;
}

.control-btn.disabled {
  opacity: 0.3;
  pointer-events: none;
}

.control-icon {
  font-size: 44rpx;
  font-weight: 300;
  line-height: 1;
}

.control-btn.minus .control-icon {
  color: #1a1a1a;
}

.control-btn.plus .control-icon {
  color: #fff;
}

.quantity-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  min-width: 200rpx;
}

.quantity-number {
  font-size: 72rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1;
  letter-spacing: -0.02em;
}

.quantity-unit {
  font-size: 24rpx;
  color: #888780;
}

/* 步长选择 */
.step-selector {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.step-label {
  font-size: 24rpx;
  color: #888780;
  flex-shrink: 0;
}

.step-options {
  display: flex;
  gap: 12rpx;
  flex: 1;
}

.step-option {
  flex: 1;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #666;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
}

.step-option.active {
  background: #1a1a1a;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(26, 26, 26, 0.3);
}

/* 精确输入模式 */
.input-area {
  margin-bottom: 32rpx;
}

.input-row {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 0 24rpx;
  height: 96rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.input-prefix {
  font-size: 26rpx;
  color: #888780;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.input-field {
  flex: 1;
  height: 96rpx;
  font-size: 32rpx;
  color: #1a1a1a;
  font-weight: 500;
}

.input-suffix {
  font-size: 26rpx;
  color: #888780;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* 数字键盘 */
.number-pad {
  background: #fff;
  border-radius: 24rpx;
  padding: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.pad-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.pad-row:last-child {
  margin-bottom: 0;
}

.pad-key {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f0eb;
  border-radius: 16rpx;
  font-size: 36rpx;
  color: #1a1a1a;
  font-weight: 500;
  transition: all 0.15s;
}

.pad-key:active {
  background: #e8e5e0;
  transform: scale(0.96);
}

.pad-key.delete {
  background: #fff3f0;
}

.pad-key.delete:active {
  background: #ffe8e0;
}

/* 底部操作栏 */
.modal-footer {
  position: sticky;
  bottom: 0;
  background: #f5f0eb;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.preview-info {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 16rpx;
}

.preview-info.error {
  background: #fef0f0;
}

.preview-text {
  font-size: 26rpx;
  color: #1a1a1a;
  font-weight: 500;
}

.preview-error-text {
  font-size: 26rpx;
  color: #ff4d4f;
  font-weight: 500;
}

.footer-buttons {
  display: flex;
  gap: 20rpx;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  line-height: 92rpx;
  padding: 0;
  letter-spacing: 0.02em;
}

.btn-cancel {
  background: #fff;
  color: #666;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.btn-confirm {
  background: #1a1a1a;
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(26, 26, 26, 0.3);
}

.btn-confirm:active {
  transform: scale(0.98);
}

.btn-confirm[disabled] {
  background: #d9d9d9;
  color: #999;
  box-shadow: none;
}
