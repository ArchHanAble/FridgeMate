<!-- pages/food-detail/food-detail.wxml -->
<view class="page-container detail-page">

  <!-- === Hero 卡片：名称 + 过期角标 + 分类标签 + 基础信息 === -->
  <view class="hero-card animate-fade-in-up">
    <!-- 名称行：左侧名称，右侧过期角标 -->
    <view class="hero-top">
      <text class="food-name">{{name || '未知食材'}}</text>
      <view class="expired-badge" wx:if="{{expiryLevel === 'expired'}}">
        <view class="expired-dot"></view>
        <text class="expired-text">已过期 {{daysRemaining}} 天</text>
      </view>
      <view class="expiring-badge" wx:elif="{{expiryLevel === 'expiring'}}">
        <view class="expiring-dot"></view>
        <text class="expiring-text">即将过期</text>
      </view>
    </view>

    <!-- 分类标签 -->
    <view class="category-tag">
      <text>{{categoryIcon}} {{categoryLabel}}</text>
    </view>

    <!-- 信息行：品牌 / 数量 / 位置（带分隔线） -->
    <view class="info-row">
      <view class="info-item" wx:if="{{brand}}">
        <text class="info-label">品牌</text>
        <text class="info-value">{{brand}}</text>
      </view>
      <view class="info-divider" wx:if="{{brand}}"></view>

      <view class="info-item">
        <text class="info-label">数量</text>
        <text class="info-value">{{quantity}} {{unit || '个'}}</text>
      </view>
      <view class="info-divider"></view>

      <view class="info-item" wx:if="{{locationLabel}}">
        <text class="info-label">位置</text>
        <text class="info-value">{{locationIcon}} {{locationLabel}}</text>
      </view>
    </view>
  </view>

  <!-- === 保质期区（时间轴 + 进度条）=== -->
  <view class="card section-card animate-fade-in-up" wx:if="{{expiryDate}}" style="animation-delay: 0.08s">
    <view class="section-title">保质期</view>

    <!-- 时间轴（左对齐式） -->
    <view class="timeline">
      <!-- 渐变竖线背景 -->
      <view class="timeline-line"></view>

      <!-- 生产日期 -->
      <view class="timeline-item">
        <view class="tl-dot tl-dot--green"></view>
        <view class="tl-content">
          <text class="tl-label">生产日期</text>
          <text class="tl-date">{{productionDate || '未设置'}}</text>
        </view>
      </view>

      <!-- 过期日期 -->
      <view class="timeline-item">
        <view class="tl-dot tl-dot--{{expiryLevel === 'expired' ? 'red' : expiryLevel === 'expiring' ? 'orange' : 'gray'}}"></view>
        <view class="tl-content">
          <text class="tl-label">过期日期</text>
          <text class="tl-date tl-date--{{expiryLevel}}">{{expiryDate}}</text>
        </view>
      </view>

      <!-- 今天标记（仅过期/临期时显示在时间轴上） -->
      <view class="timeline-item" wx:if="{{showTodayMarker && (expiryLevel === 'expired' || expiryLevel === 'expiring')}}">
        <view class="tl-dot tl-dot--today"></view>
        <view class="tl-content">
          <text class="tl-label">今天</text>
          <view class="tl-today-badge">
            <text wx:if="{{expiryLevel === 'expired'}}">已超期 {{daysRemaining}} 天</text>
            <text wx:else>还剩 {{daysRemaining}} 天</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部进度条 -->
    <view class="progress-bar" wx:if="{{shelfLifeDays > 0}}">
      <view
        class="progress-fill progress-fill--{{expiryLevel}}"
        style="width: {{expiryProgress}}%"
      ></view>
    </view>
    <view class="progress-label" wx:if="{{shelfLifeDays > 0}}">
      <text>{{shelfLifeDays}}天保质期</text>
      <text wx:if="{{expiryLevel === 'expired'}}">已过期</text>
      <text wx:elif="{{expiryLevel === 'expiring'}}">即将过期</text>
      <text wx:else>新鲜</text>
    </view>
  </view>

  <!-- === AI 处理建议（暖色调卡片）=== -->
  <view class="ai-section animate-fade-in-up" wx:if="{{aiAdvice}}" style="animation-delay: 0.14s">
    <view class="ai-header">
      <view class="ai-icon">
        <text class="ai-icon-inner">✦</text>
      </view>
      <text class="ai-title">AI 处理建议</text>
    </view>
    <text class="ai-body">{{aiAdvice}}</text>
    <view class="ai-tip" wx:if="{{expiryLevel === 'expired'}}">
      <text class="ai-tip-icon">⏰</text>
      <text>建议 24 小时内处理，冷藏不可再延期</text>
    </view>
  </view>

  <!-- === 备注 === -->
  <view class="card note-card animate-fade-in-up" style="animation-delay: 0.2s" wx:if="{{note}}">
    <view class="section-title"><text>📝 备注</text></view>
    <text class="note-content">{{note}}</text>
  </view>

  <!-- === 底部操作按钮（黑主色+白描边辅色）=== -->
  <view class="bottom-actions safe-area-bottom">
    <button class="btn-primary" bindtap="goRecipes" hover-class="hover-scale">
      <text>🍳 查看可用菜谱</text>
    </button>
    <button class="btn-edit" bindtap="editItem" hover-class="hover-scale-light">
      <text>✏️ 编辑</text>
    </button>
    <button class="btn-secondary" catchtap="showAdjustStock" hover-class="hover-scale-light" wx:if="{{!_id.startsWith('demo_')}}">
      <text>📦 调整库存</text>
    </button>
  </view>
</view>

<!-- === 调整库存弹窗 === -->
<view class="modal-mask" wx:if="{{showStockModal}}" bindtap="hideAdjustStock">
  <view class="modal-container" catchtap="preventBubble">
    <!-- 顶部拖拽指示条 -->
    <view class="modal-indicator"></view>
    
    <!-- 标题栏 -->
    <view class="modal-header">
      <view class="modal-title-group">
        <text class="modal-icon">📦</text>
        <text class="modal-title">调整库存</text>
      </view>
      <view class="modal-close" bindtap="hideAdjustStock">
        <text class="close-icon">✕</text>
      </view>
    </view>
    
    <!-- 食材信息卡片 -->
    <view class="stock-card">
      <view class="stock-card-left">
        <text class="stock-name">{{name}}</text>
        <view class="stock-current-row">
          <text class="stock-current-label">当前库存</text>
          <text class="stock-current-value">{{quantity}}</text>
          <text class="stock-unit">{{unit}}</text>
        </view>
      </view>
      <view class="stock-card-badge">
        <text class="badge-text">库存</text>
      </view>
    </view>
    
    <!-- 调整操作区 -->
    <view class="adjust-area">
      <!-- 快速调整模式：大按钮 + 数字显示 -->
      <view class="quick-adjust" wx:if="{{adjustMode === 'quick'}}">
        <view class="quick-adjust-header">
          <text class="adjust-label">快速调整</text>
          <view class="mode-switch-btn" bindtap="switchAdjustMode" data-mode="precise">
            <text class="switch-text">精确输入</text>
          </view>
        </view>
        
        <!-- 核心操作区：加减按钮 + 数字 -->
        <view class="core-controls">
          <view class="control-btn minus {{previewQuantity <= 0 ? 'disabled' : ''}}" bindtap="adjustDelta" data-value="{{-stepSize}}">
            <text class="control-icon">−</text>
          </view>
          
          <view class="quantity-display">
            <text class="quantity-number">{{previewQuantity >= 0 ? previewQuantity : quantity}}</text>
            <text class="quantity-unit">{{unit}}</text>
          </view>
          
          <view class="control-btn plus" bindtap="adjustDelta" data-value="{{stepSize}}">
            <text class="control-icon">+</text>
          </view>
        </view>
        
        <!-- 步长选择 -->
        <view class="step-selector">
          <text class="step-label">步长</text>
          <view class="step-options">
            <view class="step-option {{stepSize === 1 ? 'active' : ''}}" bindtap="setStepSize" data-step="1">
              <text>1</text>
            </view>
            <view class="step-option {{stepSize === 5 ? 'active' : ''}}" bindtap="setStepSize" data-step="5">
              <text>5</text>
            </view>
            <view class="step-option {{stepSize === 10 ? 'active' : ''}}" bindtap="setStepSize" data-step="10">
              <text>10</text>
            </view>
            <view class="step-option {{stepSize === 50 ? 'active' : ''}}" bindtap="setStepSize" data-step="50">
              <text>50</text>
            </view>
          </view>
        </view>
        
      </view>
      
      <!-- 精确输入模式 -->
      <view class="precise-adjust" wx:if="{{adjustMode === 'precise'}}">
        <view class="precise-adjust-header">
          <text class="adjust-label">精确调整</text>
          <view class="mode-switch-btn" bindtap="switchAdjustMode" data-mode="quick">
            <text class="switch-text">快速调整</text>
          </view>
        </view>
        
        <!-- 输入区域 -->
        <view class="input-area">
          <view class="input-row">
            <text class="input-prefix">调整后库存</text>
            <input class="input-field" type="digit" value="{{directValue}}" bindinput="onDirectInput" placeholder="输入数量" />
            <text class="input-suffix">{{unit}}</text>
          </view>
        </view>
        
        <!-- 数字键盘快捷输入 -->
        <view class="number-pad">
          <view class="pad-row">
            <view class="pad-key" bindtap="padInput" data-num="1"><text>1</text></view>
            <view class="pad-key" bindtap="padInput" data-num="2"><text>2</text></view>
            <view class="pad-key" bindtap="padInput" data-num="3"><text>3</text></view>
          </view>
          <view class="pad-row">
            <view class="pad-key" bindtap="padInput" data-num="4"><text>4</text></view>
            <view class="pad-key" bindtap="padInput" data-num="5"><text>5</text></view>
            <view class="pad-key" bindtap="padInput" data-num="6"><text>6</text></view>
          </view>
          <view class="pad-row">
            <view class="pad-key" bindtap="padInput" data-num="7"><text>7</text></view>
            <view class="pad-key" bindtap="padInput" data-num="8"><text>8</text></view>
            <view class="pad-key" bindtap="padInput" data-num="9"><text>9</text></view>
          </view>
          <view class="pad-row">
            <view class="pad-key" bindtap="padInput" data-num="0"><text>0</text></view>
            <view class="pad-key delete" bindtap="padDelete"><text>⌫</text></view>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 底部操作栏 -->
    <view class="modal-footer">
      <view class="preview-info" wx:if="{{previewQuantity >= 0 && previewQuantity !== quantity}}">
        <text class="preview-text">{{quantity}} → {{previewQuantity}} {{unit}}</text>
      </view>
      <view class="preview-info error" wx:if="{{previewQuantity < 0}}">
        <text class="preview-error-text">库存不能为负数</text>
      </view>
      <view class="footer-buttons">
        <button class="btn-cancel" bindtap="hideAdjustStock">取消</button>
        <button class="btn-confirm" bindtap="confirmAdjustStock" disabled="{{previewQuantity < 0 || previewQuantity === quantity}}">确认调整</button>
      </view>
    </view>
  </view>
</view>
